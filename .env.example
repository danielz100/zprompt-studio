# ──────────────────────────────────────────────────────────────
# zprompt-studio — env template (V14)
# Copy to .env.local. Never commit real values.
# ──────────────────────────────────────────────────────────────

# Supabase (configured in T4)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ⚠ V2: Google AI Studio key is BYOK — provided by user client-side.
# There is intentionally NO server-side GEMINI_API_KEY here.

# Public site URL
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Telemetry (V8 — opt-in only)
NEXT_PUBLIC_TELEMETRY_ENABLED=false

# n8n webhook (T26 — optional integration)
NEXT_PUBLIC_N8N_WEBHOOK_URL=
